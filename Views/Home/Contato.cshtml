        </div>
        <div class="evento-tipo">
            <div class="rede-social">🏢</div>
            <p>Eventos<br>Corporativos</p>
        </div>
        <div class="evento-tipo">
            <div class="rede-social">🎡</div>
            <p>Feiras e<br>Confraternizações</p>
        </div>
    </div>
</section>