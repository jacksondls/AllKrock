        <!-- FORMULÁRIO -->
        <div class="contato-form">
            <h2 class="secao-titulo" style="text-align:left">🍿 ENVIE SUA MENSAGEM 🍿</h2>

            <div class="form-grupo">
                <label>Seu nome</label>
                <input type="text" placeholder="Digite seu nome" class="form-input" />
            </div>
            <div class="form-grupo">
                <label>Seu e-mail</label>
                <input type="email" placeholder="Digite seu e-mail" class="form-input" />
            </div>
            <div class="form-grupo">
                <label>Assunto</label>
                <select class="form-input">
                    <option>Selecione um assunto</option>
                    <option>Pedido</option>
                    <option>Eventos</option>
                    <option>Dúvidas</option>
                    <option>Sugestões</option>
                </select>
            </div>
            <div class="form-grupo">
                <label>Mensagem</label>
                <textarea placeholder="Escreva sua mensagem aqui..." class="form-input form-textarea"></textarea>
            </div>
            <button class="btn-enviar">ENVIAR MENSAGEM →</button>
        </div>
    </div>
</section>

<!-- VAI FAZER UM EVENTO? -->
